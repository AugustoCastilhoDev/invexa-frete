APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Para notificações reais por e-mail, use MAIL_MAILER=resend e preencha RESEND_API_KEY
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Comprovantes e documentos fiscais: em dev fica em disco local ("public").
# Em produção, defina UPLOADS_DISK=r2 e preencha as credenciais da Cloudflare R2 abaixo.
UPLOADS_DISK=public
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# Cobrança recorrente (Asaas). ASAAS_ENV=sandbox para testar sem gerar cobrança real;
# troque para production só quando for cobrar clientes de verdade. Sem a chave configurada,
# o cadastro de empresa continua funcionando normalmente — só não cria a assinatura no Asaas.
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=

# Emissão de CT-e/MDF-e (Focus NFe). Estrutura fica pronta mas inerte enquanto
# nenhum plano for contratado — sem o token, a ativação por empresa (tela
# /empresas/{id}) simplesmente falha com aviso no log, sem travar o resto do
# sistema. O ambiente (homologação/produção) é configurado por empresa, não aqui.
FOCUS_NFE_TOKEN_CONTA_PRINCIPAL=
FOCUS_NFE_WEBHOOK_TOKEN=

# Backup automático (banco de dados + uploads locais), diário via scheduler
# do Laravel — ver routes/console.php e config/backup.php. Sem a senha, o
# backup roda sem criptografia (não recomendado em produção).
BACKUP_ARCHIVE_PASSWORD=
BACKUP_NOTIFICATION_EMAIL=contato@invexa-app.com.br

# Retenção de dados pessoais (LGPD) — ver config/lgpd.php. Opcional: todas têm
# default seguro no código, só precisa preencher se for ajustar o prazo.
LGPD_RETENCAO_MOTORISTAS_ANOS=5
LGPD_RETENCAO_CLIENTES_ANOS=5
LGPD_RETENCAO_USUARIOS_ANOS=5
LGPD_RETENCAO_LOGS_ACESSO_MESES=12

VITE_APP_NAME="${APP_NAME}"
